{
  "$schema": "https://opencode.ai/config.json",
  "snapshot": false,
  "watcher": {
    "ignore": ["data/**", "outputs/**", "models/**", "submissions/**", "mlruns/**", "node_modules/**", ".git/**"]
  },
  "plugin": ["./plugin/rogii-guards.ts"],
  "mcp": {
    "linear": {
      "type": "local",
      "command": ["cmd", "/c", "npx", "-y", "@tacticlaunch/mcp-linear"],
      "environment": {
        "LINEAR_API_TOKEN": "{env:LINEAR_API_TOKEN}"
      },
      "enabled": true
    }
  }
}
